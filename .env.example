# Jarvis AI Assistant Environment Configuration
# Copy this file to .env and fill in your actual API keys

# OpenWeather API (for weather information)
# Get your free API key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Wolfram Alpha API (for calculations and complex queries)
# Get your free API key from: https://developer.wolframalpha.com/portal/myapps/
WOLFRAM_ALPHA_API_KEY=your_wolfram_alpha_api_key_here

# News API (for news headlines)
# Get your free API key from: https://newsapi.org/
NEWS_API_KEY=your_news_api_key_here

# Email Configuration (for sending emails)
# Use Gmail App Password for security: https://support.google.com/accounts/answer/185833
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# Optional: OpenAI API (for ChatGPT integration - future feature)
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# Assistant Configuration
# ASSISTANT_NAME=Jarvis
# WAKE_WORD=jarvis

# TTS Configuration
# TTS_RATE=170
# TTS_VOLUME=0.9

# Speech Recognition Settings
# LISTEN_TIMEOUT=3
# PHRASE_TIME_LIMIT=5

# Notes:
# - Never commit your actual .env file to version control
# - Keep your API keys secure and don't share them
# - Some APIs have usage limits on free tiers
# - Gmail requires "App Passwords" for security - don't use your regular password